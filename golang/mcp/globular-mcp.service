[Unit]
Description=Globular MCP Server
After=network-online.target globular-etcd.service
Wants=network-online.target

[Service]
Type=simple
User=globular
Group=globular
WorkingDirectory=/var/lib/globular/mcp
Environment=GLOBULAR_MCP_CONFIG=/var/lib/globular/mcp/config.json
ExecStart=/usr/lib/globular/bin/globular-mcp-server
Restart=on-failure
RestartSec=5
LimitNOFILE=524288
StandardInput=null
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
