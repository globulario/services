{
  "service": {
    "name": "catalog.CatalogService",
    "version": "0.1.0",
    "publisherId": "globular.io",
    "domain": "globular.internal",
    "protoPackage": "catalog",
    "protoService": "CatalogService"
  },
  "runtime": {
    "kind": "dotnet",
    "entrypoint": "dotnet CatalogService.Host.dll",
    "workingDirectory": "."
  },
  "network": {
    "grpcPort": 50051,
    "tlsEnabled": false
  },
  "health": {
    "enabled": true,
    "mode": "grpc"
  },
  "discovery": {
    "enabled": false,
    "registerOnStartup": false
  },
  "lifecycle": {
    "keepAlive": true,
    "restartPolicy": "on-failure"
  }
}
