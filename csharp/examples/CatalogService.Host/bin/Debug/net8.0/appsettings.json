{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Globular": {
    "Service": {
      "Name": "catalog.CatalogService",
      "DisplayName": "Catalog Service",
      "Version": "0.1.0",
      "PublisherId": "globular.io",
      "Domain": "globular.internal",
      "ProtoPackage": "catalog",
      "ProtoService": "CatalogService"
    },
    "Network": {
      "GrpcBindAddress": "0.0.0.0",
      "GrpcPort": 50051,
      "TlsEnabled": false
    },
    "Health": {
      "Enabled": true,
      "Mode": "grpc"
    },
    "Discovery": {
      "Enabled": false,
      "RegisterOnStartup": false
    },
    "Lifecycle": {
      "KeepAlive": true,
      "RestartPolicy": "on-failure"
    }
  }
}
